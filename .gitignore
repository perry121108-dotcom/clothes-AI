__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
dist/
build/

# ── 虛擬環境 ──
.venv/
venv/
env/

# ── 系統檔案 ──
.DS_Store
Thumbs.db

# ── IDE ──
.vscode/
.idea/

# ── 暫存媒體檔案 ──
*.mp3
*.mp4

